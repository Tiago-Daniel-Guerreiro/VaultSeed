import { Button, LineEdit, ScrollView, Spinner } from "std-widgets.slint";

export global ClipboardActions {
    callback copy(string);
}

// PALETA DE CORES - ponto único de verdade
export global Palette {
    // Fundos
    out property <color> bg-base:       #21252b;  // janela
    out property <color> bg-panel:      #282c34;  // painéis / cards
    out property <color> bg-sidebar:    #1e2227;  // sidebar
    out property <color> bg-input:      #1a1d23;  // campos de texto
    out property <color> bg-hover:      #2f333d;  // hover geral
    out property <color> bg-active:     #3a3f4b;  // item selecionado

    // Bordas
    out property <color> border:        #3a3f4b;
    out property <color> border-focus:  #61afef;

    // Texto
    out property <color> text-primary:  #abb2bf;
    out property <color> text-heading:  #ffffff;
    out property <color> text-muted:    #5c6370;
    out property <color> text-link:     #61afef;

    // Semântica
    out property <color> accent:        #61afef;  // azul  - acção principal
    out property <color> success:       #98c379;  // verde - sucesso
    out property <color> warning:       #e5c07b;  // amarelo - aviso
    out property <color> danger:        #e06c75;  // vermelho - erro / perigo
    out property <color> info:          #56b6c2;  // ciano - informação

    // Sobreposição de modal
    out property <color> overlay:       #000000aa;

    // Fundos semânticos (cartões de aviso/erro/sucesso/info) - antes inline
    out property <color> bg-danger:        #2e1a1a;
    out property <color> bg-danger-strong: #3a1a1a;
    out property <color> bg-warning:       #2e2714;
    out property <color> bg-success:       #1a3326;
    out property <color> bg-info:          #12292e;
}

// TOKENS - dimensões, espaçamento e tipografia. Ponto único de verdade para manter consistência e escala em todas as views.
export global Tokens {
    // Larguras / layout
    out property <length> list-col-width:    240px;  // coluna-lista / sub-sidebar
    out property <length> mobile-breakpoint: 800px;  // abaixo disto: colapsa
    out property <length> sidebar-collapsed: 44px;

    // Alturas
    out property <length> header-height:   56px;  // cabeçalho de coluna
    out property <length> topbar-height:   48px;
    out property <length> input-height:    36px;
    out property <length> nav-item-height: 44px;

    // Espaçamento / raio
    out property <length> pad-view:  24px;
    out property <length> pad-card:  16px;
    out property <length> gap-md:    12px;
    out property <length> gap-sm:    8px;
    out property <length> radius:    8px;
    out property <length> radius-sm: 6px;

    // Tipografia
    out property <length> fs-heading: 20px;  // título de detalhe
    out property <length> fs-title:   16px;  // título de secção
    out property <length> fs-column:  15px;  // título de coluna / topbar
    out property <length> fs-body:    13px;
    out property <length> fs-label:   11px;
    out property <length> fs-micro:   10px;
}

export global WindowMetrics {
    in-out property <length> avail-width: 1000px;
}

// TEXTO COM FONTES MISTAS - cada run de texto (ex: emoji vs. resto) é desenhado
// com a font-family adequada. A font-family por defeito da app (Noto Sans) não
// cobre emojis, e a fonte de emojis (Noto Emoji) não cobre letras - texto que
// mistura os dois (ex: senhas geradas) precisa de "runs" com fonts diferentes
// lado a lado, já que o Slint não escolhe a fonte por carácter dentro do mesmo Text.
export struct TextRun {
    text:  string,
    emoji: bool,
}

// Uma linha de "runs" - ver MixedFontText. A divisão em linhas é feita do
// lado do Rust (helpers::split_emoji_runs), já que um HorizontalLayout de
// "runs" não quebra linha por si só.
export struct TextLine {
    runs: [TextRun],
}

export component MixedFontText inherits VerticalLayout {
    in property <string>     raw-text: "";
    in property <length>     font-size: 14px;
    in property <int>        font-weight: 400;
    in property <color>      color: Palette.text-heading;

    property <int> dynamic-chars-limit: max(6, floor(WindowMetrics.avail-width / (root.font-size * 0.6)));
    pure callback compute-lines(string /*texto*/, int /*chars-por-linha*/) -> [TextLine];
    property <[TextLine]> lines: root.compute-lines(root.raw-text, root.dynamic-chars-limit);

    spacing: 0px;

    for line in root.lines : HorizontalLayout {
        spacing: 0px;

        for run in line.runs : Text {
            text:        run.text;
            font-size:   root.font-size;
            font-weight: root.font-weight;
            color:       root.color;
            font-family: run.emoji ? "Noto Emoji" : "Noto Sans";
            wrap:        word-wrap;
            vertical-alignment: center;
        }
    }
}

// DIVISOR HORIZONTAL
export component Divider inherits Rectangle {
    height: 1px;
    background: Palette.border;
}

// "X" de fechar.
export component IconClose inherits Rectangle {
    in property <length> size:  12px;
    in property <color>  icon-color: Palette.text-muted;
    width: size; height: size;
    Path {
        stroke:         root.icon-color;
        stroke-width:   1.5px;
        viewbox-width:  10;
        viewbox-height: 10;
        commands:       "M 1 1 L 9 9 M 9 1 L 1 9";
        animate stroke { duration: 100ms; }
    }
}

// Menu "mais opções" (três pontos horizontais) - usado p.ex. no botão
// "Sistema" da topbar, em vez de um Text literal "...".
export component IconMore inherits Rectangle {
    in property <length> size:  18px;
    in property <color>  icon-color: Palette.text-muted;
    width: size; height: size;
    VerticalLayout {
        alignment: center;
        HorizontalLayout {
            alignment: center;
            spacing: size * 0.18;
            for _ in [0, 1, 2] : Rectangle {
                width:         size * 0.16;
                height:        size * 0.16;
                border-radius: self.width / 2;
                background:    root.icon-color;
                animate background { duration: 120ms; }
            }
        }
    }
}

// Marca de seleção (checkbox marcado).
export component IconCheck inherits Rectangle {
    in property <length> size:  12px;
    in property <color>  icon-color: Palette.bg-base;
    width: size; height: size;
    Path {
        fill:           transparent;
        stroke:         root.icon-color;
        stroke-width:   1.6px;
        viewbox-width:  10;
        viewbox-height: 10;
        commands:       "M 1.5 5.2 L 4 7.7 L 8.5 2.5";
    }
}

