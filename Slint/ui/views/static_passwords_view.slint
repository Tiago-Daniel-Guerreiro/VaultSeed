import { Button, LineEdit, ScrollView } from "std-widgets.slint";

import {
    Palette, Tokens, Divider, LabeledInput, MessageBanner,
    Card, SectionTitle, StatusBadge, KeyValueRow,
    EmptyState, BackButton, AddToggleButton, ListHeader, WindowMetrics,
    IconFolder, IconWarning, IconAsterisk, IconCheck, IconClose, CloseButton,
} from "../components/shared_components.slint";

import { AuthenticationModal } from "./login_view.slint";

import { SidebarBase } from "../components/sidebar_components.slint";

// STRUCTS DE DADOS
export struct FolderItem {
    name:            string,   // "" = raiz
    display-name:    string,   // "(raiz)" ou nome real
    normal-count:    int,
    compromised-count: int,
}

export struct StaticPasswordItem {
    uuid:        string,
    label:       string,
    folder:      string,
    compromised: bool,
}

export struct StaticPasswordDetail {
    uuid:        string,
    label:       string,
    folder:      string,
    value:       string,
    notes:       string,
    compromised: bool,
}

// FOLDER LIST ITEM - linha de pasta na coluna esquerda
component FolderListItem inherits Rectangle {
    in property <FolderItem> folder;
    in property <bool>       selected:    false;
    in property <bool>       show-normal: true;  // false = modo comprometidas

    callback clicked;

    height:        48px;
    border-radius: 6px;
    background:    selected     ? Palette.bg-active
                 : ta.has-hover ? Palette.bg-hover
                 : transparent;
    animate background { duration: 120ms; }

    ta := TouchArea { clicked => { root.clicked(); } }

        Rectangle {
        x:             0px;
        y:             (parent.height - self.height) / 2;
        width:         3px;
        height:        22px;
        border-radius: 2px;
        background:    root.selected ? Palette.accent : transparent;
        animate background { duration: 150ms; }
    }

    HorizontalLayout {
        padding-left:  12px;
        padding-right: 8px;
        spacing:       8px;
        alignment:     start;

        VerticalLayout {
            alignment: center;
            IconFolder { size: 16px; }
        }

        VerticalLayout {
            alignment:          center;
            horizontal-stretch: 1;
            spacing:            2px;

            Text {
                text:        folder.display-name;
                font-size:   13px;
                font-weight: selected ? 700 : 400;
                color:       selected ? Palette.text-heading : Palette.text-primary;
                overflow:    elide;
                animate color { duration: 120ms; }
            }

            HorizontalLayout {
                spacing: 6px;

                Text {
                    text:      show-normal ? folder.normal-count + " senha(s)" : folder.compromised-count + " comprometida(s)";
                    font-size: 11px;
                    color:     !show-normal && folder.compromised-count > 0 ? Palette.warning : Palette.text-muted;
                }
            }
        }

        Text {
            text:               selected ? ">" : "";
            color:              Palette.accent;
            font-size:          18px;
            vertical-alignment: center;
        }
    }
}

// STATIC PASSWORD LIST ITEM - linha de senha dentro de uma pasta
component StaticPasswordListItem inherits Rectangle {
    in property <StaticPasswordItem> item;
    in property <bool>               selected: false;

    callback clicked;

    height:        44px;
    border-radius: 6px;
    background:    selected     ? Palette.bg-active : ta.has-hover ? Palette.bg-hover : transparent;
    animate background { duration: 120ms; }

    ta := TouchArea { clicked => { root.clicked(); } }

        Rectangle {
        x:             0px;
        y:             (parent.height - self.height) / 2;
        width:         3px;
        height:        20px;
        border-radius: 2px;
        background:    root.selected ? Palette.accent : transparent;
        animate background { duration: 150ms; }
    }

    HorizontalLayout {
        padding-left:  16px;
        padding-right: 12px;
        spacing:       10px;
        alignment:     start;

        Text {
            text:               item.compromised ? "!" : "*";
            font-size:          14px;
            color:              item.compromised ? Palette.warning : Palette.text-muted;
            vertical-alignment: center;
        }

        Text {
            text:               item.label;
            font-size:          13px;
            font-weight:        selected ? 700 : 400;
            color:              item.compromised ? Palette.text-muted : selected ? Palette.text-heading : Palette.text-primary;
            vertical-alignment: center;
            horizontal-stretch: 1;
            overflow:           elide;
            animate color { duration: 120ms; }
        }

        if item.compromised : StatusBadge {
            label:   "COMPROMETIDA";
            variant: "warning";
        }

        Text {
            text:               selected ? ">" : "";
            color:              Palette.accent;
            font-size:          18px;
            vertical-alignment: center;
        }
    }
}

// ADD STATIC PASSWORD FORM
component AddStaticPasswordForm inherits VerticalLayout {
    in property <string> folder-name;
    in property <string> error: "";

    callback on-submit(string /*label*/, string /*value*/, string /*notes*/);
    callback on-cancel();

    alignment: start;
    spacing: 12px;
    padding: 16px;

    SectionTitle {
        title:    "Adicionar senha estática";
        subtitle: "Pasta: " + (folder-name == "" ? "(raiz)" : folder-name);
    }

    Divider {}

    label-field := LabeledInput {
        label:       "Nome";
        placeholder: "ex: Conta principal, PIN cartão";
        hint:        "Nome identificador para esta senha";
    }

    value-field := LabeledInput {
        label:       "Senha";
        placeholder: "Introduza a senha";
        is-secret:   true;
        hint:        "Será encriptada com as suas chaves mestras";
    }

    notes-field := LabeledInput {
        label:       "Notas (opcional)";
        placeholder: "Informação adicional sobre esta senha";
    }

    MessageBanner {
        message: root.error;
        variant: "error";
    }

    HorizontalLayout {
        alignment: end;
        spacing:   10px;

        Button {
            text:    "Cancelar";
            clicked => { root.on-cancel(); }
        }

        Button {
            text:    "Guardar senha ";
            primary: true;
            enabled: label-field.value != "" && value-field.value != "";
            clicked => {
                root.on-submit(
                    label-field.value,
                    value-field.value,
                    notes-field.value,
                );
            }
        }
    }
}

// STATIC PASSWORD DETAIL PANEL - detalhe + acções de uma senha estática
component StaticPasswordDetailPanel inherits VerticalLayout {
    in property <StaticPasswordDetail> detail;
    in property <bool>                 value-visible:    false;
    in property <bool>                 notes-visible:    false;
    in property <string>               error-decrypt:    "";
    in property <string>               error-compromise: "";

    // Estado interno
    in-out property <bool> show-decrypt-form:    false;
    in-out property <bool> show-compromise-form: false;
    in-out property <bool>   show-rename-form: false;
    in-out property <string> rename-value: "";
    in-out property <bool>   show-notes-edit-form: false;
    in-out property <string> notes-edit-value: "";

    callback on-view();
    callback on-view-notes();
    callback on-copy();
    callback on-close-value();
    callback on-close-notes();
    callback on-mark-compromised();
    callback on-remove();
    callback on-rename(string /*new_label*/);
    callback on-edit-notes(string /*new_notes*/);

    // alignment:start é essencial - sem isto o ScrollView pai não consegue medir a altura total do conteúdo correctamente.
    alignment: start;
    spacing:  20px;
    padding: WindowMetrics.avail-width < 700px ? 12px : 24px;

    property <bool> narrow: WindowMetrics.avail-width < 500px;

    // Cabeçalho
    if !root.narrow : HorizontalLayout {
        spacing:   12px;
        alignment: start;

        VerticalLayout {
            alignment: center;
            if detail.compromised : IconWarning { size: 24px; }
            if !detail.compromised : IconAsterisk { size: 24px; }
        }

        VerticalLayout {
            horizontal-stretch: 1;
            spacing: 2px;
            alignment: center;

            Text {
                text:        detail.label;
                font-size:   20px;
                font-weight: 700;
                color:       Palette.text-heading;
                overflow:    elide;
            }

            Text {
                text:      detail.uuid;
                font-size: 11px;
                color:     Palette.text-muted;
                overflow:  elide;
            }
        }

        VerticalLayout {
            alignment: center;
            StatusBadge {
                label:   detail.compromised ? "COMPROMETIDA" : "ATIVA";
                variant: detail.compromised ? "warning" : "success";
            }
        }
    }

    if root.narrow : VerticalLayout {
        spacing: 6px;

        HorizontalLayout {
            spacing:   10px;
            alignment: start;

            VerticalLayout {
                alignment: center;
                if detail.compromised : IconWarning { size: 20px; }
                if !detail.compromised : IconAsterisk { size: 20px; }
            }

            Text {
                text:               detail.label;
                font-size:          18px;
                font-weight:        700;
                color:              Palette.text-heading;
                vertical-alignment: center;
                horizontal-stretch: 1;
                overflow:           elide;
            }
        }

        Text {
            text:      detail.uuid;
            font-size: 11px;
            color:     Palette.text-muted;
            overflow:  elide;
        }

        StatusBadge {
            label:   detail.compromised ? "COMPROMETIDA" : "ATIVA";
            variant: detail.compromised ? "warning" : "success";
        }
    }

    Divider {}

    // Notas - escondidas atrás de "Ver notas" (autenticação) até serem desencriptadas.
    if !root.notes-visible : Rectangle {
        background:    Palette.bg-panel;
        border-radius: 8px;
        border-width:  1px;
        border-color:  Palette.border;

        VerticalLayout {
            padding: 14px;
            spacing: 10px;

            Text {
                text:        "Notas";
                font-size:   12px;
                font-weight: 700;
                color:       Palette.text-muted;
            }

            Button {
                text:    "Ver notas";
                clicked => { root.on-view-notes(); }
            }
        }
    }

    if root.notes-visible : Rectangle {
        background:    Palette.bg-panel;
        border-radius: 10px;
        border-width:  1px;
        border-color:  Palette.border;

        VerticalLayout {
            padding: 14px;
            spacing: 8px;

            HorizontalLayout {
                spacing: 6px;

                Text {
                    text:               "Notas";
                    font-size:          12px;
                    font-weight:        700;
                    color:              Palette.text-muted;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }

                CloseButton {
                    clicked => { root.on-close-notes(); }
                }
            }

            Divider {}

            Text {
                text:      detail.notes == "" ? "Sem notas." : detail.notes;
                font-size: 13px;
                color:     detail.notes == "" ? Palette.text-muted : Palette.text-primary;
                wrap:      word-wrap;
            }
        }
    }

    // Ver / Copiar senha
    Rectangle {
        background:    Palette.bg-panel;
        border-radius: 8px;
        border-width:  1px;
        border-color:  Palette.border;

        VerticalLayout {
            padding: 16px;
            spacing: 12px;

            Text {
                text:        "Aceder ao valor";
                font-size:   13px;
                font-weight: 700;
                color:       Palette.text-muted;
            }

            Divider {}

            MessageBanner {
                message: root.error-decrypt;
                variant: "error";
            }

            if !root.narrow : HorizontalLayout {
                spacing: 8px;

                Button {
                    text:               "Ver valor";
                    primary:            true;
                    horizontal-stretch: 1;
                    clicked => { root.on-view(); }
                }

                Button {
                    text:               "Copiar";
                    horizontal-stretch: 1;
                    clicked => { root.on-copy(); }
                }
            }

            if root.narrow : VerticalLayout {
                spacing: 8px;

                Button {
                    text:    "Ver valor";
                    primary: true;
                    width:   100%;
                    clicked => { root.on-view(); }
                }

                Button {
                    text:  "Copiar";
                    width: 100%;
                    clicked => { root.on-copy(); }
                }
            }

        }
    }

    if value-visible && detail.value != "" : Rectangle {
        background:    Palette.bg-panel;
        border-radius: 10px;
        border-width:  1px;
        border-color:  Palette.success;

        VerticalLayout {
            padding: 16px;
            spacing: 12px;

            HorizontalLayout {
                spacing: 8px;

                Text {
                    text:        "Senha Gerada";
                    font-size:   13px;
                    font-weight: 700;
                    color:       Palette.success;
                    horizontal-stretch: 1;
                    vertical-alignment: center;
                }

                CloseButton {
                    clicked => { root.on-close-value(); }
                }
            }

            Divider {}

            Rectangle {
                background:    Palette.bg-base;
                border-radius: 6px;
                border-width:  1px;
                border-color:  Palette.border;

                HorizontalLayout {
                    padding: 14px;

                    Text {
                        text:               detail.value;
                        font-size:          14px;
                        font-weight:        700;
                        color:              Palette.text-heading;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                        wrap:               word-wrap;
                    }
                }
            }
        }
    }

    // Comprometer senha 
    if !detail.compromised : Rectangle {
        background:    #2e2714;
        border-radius: 8px;
        border-width:  1px;
        border-color:  Palette.warning;

        VerticalLayout {
            padding: 16px;
            spacing: 12px;

            if !root.narrow : HorizontalLayout {
                spacing:   8px;
                alignment: start;

                VerticalLayout {
                    alignment: center;
                    IconWarning { size: 16px; }
                }

                VerticalLayout {
                    horizontal-stretch: 1;
                    spacing: 2px;

                    Text {
                        text:        "Marcar como comprometida";
                        font-size:   13px;
                        font-weight: 700;
                        color:       Palette.warning;
                    }

                    Text {
                        text:      "A senha ficará marcada como comprometida mas não será apagada.";
                        font-size: 11px;
                        color:     Palette.text-muted;
                        wrap:      word-wrap;
                    }
                }

                Rectangle {
                    width:         100px;
                    height:        32px;
                    border-radius: 6px;
                    background:    show-compromise-form ? Palette.warning : (comp-toggle-ta.has-hover ? Palette.bg-active : Palette.bg-hover);
                    animate background { duration: 150ms; }

                    comp-toggle-ta := TouchArea {
                        clicked => { root.show-compromise-form = !root.show-compromise-form; }
                    }

                    HorizontalLayout {
                        alignment: center;
                        spacing:   6px;

                        if show-compromise-form : VerticalLayout {
                            alignment: center;
                            IconClose { size: 10px; icon-color: Palette.bg-base; }
                        }

                        Text {
                            text:               show-compromise-form ? "Cancelar" : "Comprometer";
                            font-size:          12px;
                            font-weight:        600;
                            color:              show-compromise-form ? Palette.bg-base : Palette.text-primary;
                            vertical-alignment: center;
                            animate color { duration: 150ms; }
                        }
                    }
                }
            }

            if root.narrow : VerticalLayout {
                spacing: 8px;

                HorizontalLayout {
                    spacing:   8px;
                    alignment: start;

                    VerticalLayout {
                        alignment: center;
                        IconWarning { size: 16px; }
                    }

                    Text {
                        text:               "Marcar como comprometida";
                        font-size:          13px;
                        font-weight:        700;
                        color:              Palette.warning;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                    }
                }

                Text {
                    text:      "A senha ficará marcada como comprometida mas não será apagada.";
                    font-size: 11px;
                    color:     Palette.text-muted;
                    wrap:      word-wrap;
                }

                Rectangle {
                    width:         100%;
                    height:        32px;
                    border-radius: 6px;
                    background:    show-compromise-form ? Palette.warning : (comp-toggle-ta-n.has-hover ? Palette.bg-active : Palette.bg-hover);
                    animate background { duration: 150ms; }

                    comp-toggle-ta-n := TouchArea {
                        clicked => { root.show-compromise-form = !root.show-compromise-form; }
                    }

                    HorizontalLayout {
                        alignment: center;
                        spacing:   6px;

                        if show-compromise-form : VerticalLayout {
                            alignment: center;
                            IconClose { size: 10px; icon-color: Palette.bg-base; }
                        }

                        Text {
                            text:               show-compromise-form ? "Cancelar" : "Comprometer";
                            font-size:          12px;
                            font-weight:        600;
                            color:              show-compromise-form ? Palette.bg-base : Palette.text-primary;
                            vertical-alignment: center;
                            animate color { duration: 150ms; }
                        }
                    }
                }
            }

            if show-compromise-form : VerticalLayout {
                spacing: 10px;

                MessageBanner {
                    message: root.error-compromise;
                    variant: "error";
                }

                HorizontalLayout {
                    alignment: end;

                    Button {
                        text:    "Confirmar";
                        primary: true;
                        clicked => { root.on-mark-compromised(); root.show-compromise-form = false; }
                    }
                }
            }
        }
    }

    // Ações - editar label/notas (autenticação, indisponível para comprometidas) e mover de pasta.
    Rectangle {
        background:    Palette.bg-panel;
        border-radius: 8px;
        border-width:  1px;
        border-color:  Palette.border;

        VerticalLayout {
            padding: 16px;
            spacing: 10px;

            Text {
                text:        "Ações";
                font-size:   13px;
                font-weight: 700;
                color:       Palette.text-muted;
            }

            Divider {}

            if !detail.compromised && !root.show-rename-form : HorizontalLayout {
                spacing:   8px;
                alignment: start;

                Button {
                    text: "Editar label";
                    clicked => {
                        root.rename-value     = detail.label;
                        root.show-rename-form = true;
                    }
                }
            }

            if root.show-rename-form : VerticalLayout {
                spacing: 6px;

                LineEdit {
                    text <=> root.rename-value;
                    accepted => {
                        if root.rename-value != "" {
                            root.on-rename(root.rename-value);
                        }
                        root.show-rename-form = false;
                    }
                }

                HorizontalLayout {
                    spacing:   6px;
                    alignment: end;

                    Button {
                        text:    "Cancelar";
                        clicked => { root.show-rename-form = false; }
                    }
                    Button {
                        text:    "Guardar";
                        primary: true;
                        enabled: root.rename-value != "";
                        clicked => {
                            root.on-rename(root.rename-value);
                            root.show-rename-form = false;
                        }
                    }
                }
            }

            if !detail.compromised && !root.show-notes-edit-form : HorizontalLayout {
                spacing:   8px;
                alignment: start;

                Button {
                    text: "Editar notas";
                    clicked => {
                        root.notes-edit-value    = detail.notes;
                        root.show-notes-edit-form = true;
                    }
                }
            }

            if root.show-notes-edit-form : VerticalLayout {
                spacing: 6px;

                LineEdit {
                    text <=> root.notes-edit-value;
                    accepted => {
                        root.on-edit-notes(root.notes-edit-value);
                        root.show-notes-edit-form = false;
                    }
                }

                HorizontalLayout {
                    spacing:   6px;
                    alignment: end;

                    Button {
                        text:    "Cancelar";
                        clicked => { root.show-notes-edit-form = false; }
                    }
                    Button {
                        text:    "Guardar";
                        primary: true;
                        clicked => {
                            root.on-edit-notes(root.notes-edit-value);
                            root.show-notes-edit-form = false;
                        }
                    }
                }
            }

        }
    }

    Rectangle {
        background:    #2e1a1a;
        border-radius: 8px;
        border-width:  1px;
        border-color:  Palette.danger;

        VerticalLayout {
        if !root.narrow : HorizontalLayout {
            padding:   16px;
            spacing:   12px;
            alignment: start;

            VerticalLayout {
                horizontal-stretch: 1;
                spacing: 2px;

                Text {
                    text:      "Remover senha";
                    font-size: 13px;
                    color:     Palette.danger;
                    font-weight: 700;
                }

                Text {
                    text:      "Remove permanentemente esta senha e o seu valor encriptado. Irreversível.";
                    font-size: 11px;
                    color:     Palette.text-muted;
                    wrap:      word-wrap;
                }
            }

            Button {
                text:    "Remover";
                clicked => { root.on-remove(); }
            }
        }

        if root.narrow : VerticalLayout {
            padding: 16px;
            spacing: 10px;

            Text {
                text:      "Remover senha";
                font-size: 13px;
                color:     Palette.danger;
                font-weight: 700;
            }

            Text {
                text:      "Remove permanentemente esta senha e o seu valor encriptado. Irreversível.";
                font-size: 11px;
                color:     Palette.text-muted;
                wrap:      word-wrap;
            }

            Button {
                text:    "Remover";
                width:   100%;
                clicked => { root.on-remove(); }
            }
        }
        }
    }
}

// FOLDER MANAGEMENT PANEL - renomear e remover pastas
component FolderManagementPanel inherits VerticalLayout {
    in property <[FolderItem]> folders;
    in property <string>       error-rename: "";
    in property <string>       error-remove: "";
    in property <string>       error-create: "";

    callback on-rename(string /*old_name*/, string /*new_name*/);
    callback on-remove(string /*folder_name*/);
    callback on-create(string /*name*/);
    callback on-close();

    alignment: start;
    spacing: 20px;
    padding: WindowMetrics.avail-width < 700px ? 12px : 24px;

    SectionTitle {
        title:    "Gerir pastas";
        subtitle: "Renomear ou remover pastas existentes.";
    }

    Divider {}

    // Criar pasta
    Rectangle {
        background:    Palette.bg-panel;
        border-radius: 8px;
        border-width:  1px;
        border-color:  Palette.border;

        VerticalLayout {
            padding: 14px;
            spacing: 10px;

            Text {
                text:        "Nova pasta";
                font-size:   14px;
                font-weight: 600;
                color:       Palette.text-heading;
            }

            new-folder-field := LabeledInput {
                label:       "Nome da pasta";
                placeholder: "ex: trabalho";
            }

            MessageBanner {
                message: error-create;
                variant: "error";
            }

            HorizontalLayout {
                alignment: end;

                Button {
                    text:    "Criar pasta";
                    primary: true;
                    enabled: new-folder-field.value != "";
                    clicked => {
                        root.on-create(new-folder-field.value);
                        new-folder-field.value = "";
                    }
                }
            }
        }
    }

    // Lista de pastas com acções inline
    for f in folders : Rectangle {
        background:    Palette.bg-panel;
        border-radius: 8px;
        border-width:  1px;
        border-color:  Palette.border;

        VerticalLayout {
            padding: 14px;
            spacing: 10px;

            HorizontalLayout {
                spacing:   10px;
                alignment: start;

                VerticalLayout {
                    alignment: center;
                    IconFolder { size: 16px; }
                }

                VerticalLayout {
                    horizontal-stretch: 1;
                    spacing: 2px;
                    alignment: center;

                    Text {
                        text:        f.display-name;
                        font-size:   14px;
                        font-weight: 600;
                        color:       Palette.text-heading;
                    }

                    Text {
                        text:      f.normal-count + " senha(s) · " + f.compromised-count + " comprometida(s)";
                        font-size: 11px;
                        color:     Palette.text-muted;
                    }
                }
            }

            // Só permite renomear/remover pastas com nome (não a raiz)
            if f.name != "" : VerticalLayout {
                spacing: 8px;

                new-name-field := LabeledInput {
                    label:       "Novo nome";
                    placeholder: f.name;
                    hint:        "Deixe vazio para cancelar a renomeação";
                }

                HorizontalLayout {
                    spacing:   8px;
                    alignment: end;

                    Button {
                        text:    "Renomear";
                        enabled: new-name-field.value != "" && new-name-field.value != f.name;
                        clicked => { root.on-rename(f.name, new-name-field.value); }
                    }

                    Button {
                        text:    "Remover pasta";
                        clicked => { root.on-remove(f.name); }
                    }
                }
            }

            if f.name == "" : Text {
                text:      "A pasta raiz não pode ser renomeada nem removida.";
                font-size: 11px;
                color:     Palette.text-muted;
            }
        }
    }

    MessageBanner {
        message: error-rename != "" ? error-rename : error-remove;
        variant: "error";
    }

    HorizontalLayout {
        alignment: end;

        Button {
            text:    "Fechar";
            clicked => { root.on-close(); }
        }
    }
}

export component StaticPasswordsView inherits Rectangle {
    width:      100%;
    height:     100%;
    background: Palette.bg-base;

    in property <string>                  device-uuid;
    in property <string>                  device-name;
    in property <[FolderItem]>            folders:               [];
    in property <int>                     selected-folder-index: -1;
    in property <[StaticPasswordItem]>    passwords:             [];
    in property <int>                     selected-pw-index:     -1;
    in property <StaticPasswordDetail>    selected-detail;
    in property <bool>                    value-visible:         false;
    in property <bool>                    notes-visible:         false;
    in property <bool>                    show-compromised-mode: false;

    // Erros
    in property <string> error-add:        "";
    in property <string> error-decrypt:    "";
    in property <string> error-compromise: "";
    in property <string> error-rename:     "";
    in property <string> error-remove:     "";
    in property <string> error-create:     "";

    // Estado interno
    in-out property <bool> show-add-form:    false;
    in-out property <bool> show-folder-mgmt: false;
    // Navega dentro do painel direito: lista -> detalhe
    private property <bool> sp-showing-detail: root.selected-pw-index >= 0 && !root.show-add-form && !root.show-folder-mgmt;

    // Auth overlay
    private property <string> sp-auth-action:   "";
    private property <bool>   sp-show-auth:     false;
    private property <string> sp-pending-label: "";
    private property <string> sp-pending-value: "";
    private property <string> sp-pending-notes: "";

    // Responsividade
    in property <length> avail-width: 1000px;

    // Callbacks -> Rust
    callback on-select-folder(string /*folder_name*/, bool /*compromised_mode*/);
    callback on-select-password(string /*uuid*/);
    callback on-add(string /*label*/, string /*value*/, string /*notes*/, string /*k1*/, string /*k2*/);
    callback on-view(string /*uuid*/, string /*k1*/, string /*k2*/);
    callback on-view-notes(string /*uuid*/, string /*k1*/, string /*k2*/);
    callback on-copy(string /*uuid*/, string /*k1*/, string /*k2*/);
    callback on-mark-compromised(string /*uuid*/, string /*k1*/, string /*k2*/);
    callback on-close-value();
    callback on-close-notes();
    callback on-remove-request(string /*uuid*/);
    callback on-rename(string /*uuid*/, string /*new_label*/, string /*k1*/, string /*k2*/);
    callback on-edit-notes(string /*uuid*/, string /*new_notes*/, string /*k1*/, string /*k2*/);
    callback on-rename-folder(string /*old*/, string /*new*/);
    callback on-remove-folder(string /*name*/);
    callback on-create-folder(string /*name*/);
    callback on-toggle-compromised-mode();
    callback on-back();

    HorizontalLayout {
    spacing: 0px;

    sp-sidebar := SidebarBase {
        avail-width: root.avail-width;
        flush:       true;

        VerticalLayout {
            visible: !sp-sidebar.narrow || !sp-sidebar.minimized;
            spacing: 0px;

            // Cabeçalho: Voltar + título + botão + (gere pastas)
            ListHeader {
                title:       "Pastas de Senhas estáticas";
                subtitle:    root.device-name;
                show-add:    true;
                add-active:  root.show-folder-mgmt;
                show-toggle: sp-sidebar.narrow;
                toggle-open: true;
                toggle => { sp-sidebar.minimized = true; }
                back   => { root.on-back(); }
                add    => {
                    root.show-folder-mgmt = !root.show-folder-mgmt;
                    root.show-add-form    = false;
                    if sp-sidebar.narrow { sp-sidebar.minimized = true; }
                }
            }

            // Rectangle como contentor clicável (TouchArea dentro, não irmão)
            Rectangle {
                height:     40px;
                background: root.show-compromised-mode ? #2e2714 : (comp-toggle-ta.has-hover ? Palette.bg-hover : transparent);
                animate background { duration: 120ms; }

                // Linha separadora inferior
                Rectangle {
                    y: parent.height - 1px;
                    width: 100%; height: 1px;
                    background: Palette.border;
                }

                comp-toggle-ta := TouchArea {
                    clicked => { root.on-toggle-compromised-mode(); }
                }

                HorizontalLayout {
                    padding-left:  14px;
                    padding-right: 14px;
                    spacing:       10px;
                    alignment:     center;

                    // Checkbox visual
                    VerticalLayout {
                        alignment: center;
                        Rectangle {
                            width:         16px;
                            height:        16px;
                            border-radius: 3px;
                            border-width:  1.5px;
                            border-color:  root.show-compromised-mode ? Palette.warning : Palette.border;
                            background:    root.show-compromised-mode ? Palette.warning : transparent;
                            animate border-color { duration: 120ms; }
                            animate background   { duration: 120ms; }

                            if root.show-compromised-mode : IconCheck {
                                size:       10px;
                                icon-color: Palette.bg-base;
                                x: (parent.width  - self.width)  / 2;
                                y: (parent.height - self.height) / 2;
                            }
                        }
                    }

                    Text {
                        text:               "Comprometidas";
                        font-size:          12px;
                        color:              root.show-compromised-mode ? Palette.warning : Palette.text-muted;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                        animate color { duration: 120ms; }
                    }
                }
            }

            ScrollView {
                vertical-stretch:   1;
                horizontal-stretch: 1;

                VerticalLayout {
                    padding: 6px;
                    spacing: 2px;

                    if root.folders.length == 0 : EmptyState {
                        title:   "Sem pastas";
                        message: "Adicione uma senha para criar a primeira pasta.";
                    }

                    for f[i] in root.folders : FolderListItem {
                        folder:      f;
                        selected:    i == root.selected-folder-index;
                        show-normal: !root.show-compromised-mode;
                        clicked => {
                            root.show-add-form    = false;
                            root.show-folder-mgmt = false;
                            root.on-select-folder(f.name, root.show-compromised-mode);
                            if sp-sidebar.narrow { sp-sidebar.minimized = true; }
                        }
                    }
                }
            }
        }
    }

    Rectangle {
        horizontal-stretch: 1;
        background: Palette.bg-base;

        VerticalLayout {
            spacing: 0px;

            Rectangle {
                height:     Tokens.header-height;
                background: Palette.bg-panel;

                Rectangle {
                    y: parent.height - 1px;
                    width: 100%; height: 1px;
                    background: Palette.border;
                }

                HorizontalLayout {
                    padding-left:  14px;
                    padding-right: 10px;
                    spacing:       8px;
                    alignment:     start;

                    // Botão voltar para lista (quando a ver detalhe ou form)
                    if root.sp-showing-detail || root.show-add-form || root.show-folder-mgmt : VerticalLayout {
                        alignment: center;
                        TouchArea {
                            width:  44px;
                            height: 44px;
                            clicked => {
                                root.show-add-form    = false;
                                root.show-folder-mgmt = false;
                                root.on-select-password("");
                            }

                            Rectangle {
                                width:         36px;
                                height:        36px;
                                border-radius: 5px;
                                background:    parent.has-hover ? Palette.bg-hover : transparent;
                                animate background { duration: 100ms; }

                                Text {
                                    text:                 "←";
                                    font-size:            16px;
                                    horizontal-alignment: center;
                                    vertical-alignment:   center;
                                    color:                Palette.text-primary;
                                }
                            }
                        }
                    }

                    VerticalLayout {
                        horizontal-stretch: 1;
                        alignment:          center;
                        spacing:            1px;

                        Text {
                            text: root.show-folder-mgmt   ? "Gerir pastas"
                                : root.show-add-form       ? "Nova senha"
                                : root.sp-showing-detail   ? root.selected-detail.label
                                : (root.selected-folder-index >= 0 && root.selected-folder-index < root.folders.length)
                                    ? root.folders[root.selected-folder-index].display-name
                                    : "Selecione uma pasta";
                            font-size:          13px;
                            font-weight:        700;
                            color:              Palette.text-heading;
                            overflow:           elide;
                        }

                        if !root.sp-showing-detail && !root.show-add-form && !root.show-folder-mgmt && root.selected-folder-index >= 0 : Text {
                            text:      root.passwords.length + " senha(s)";
                            font-size: 11px;
                            color:     Palette.text-muted;
                        }
                    }

                    // Botão + (adicionar senha) - só quando a ver a lista de senhas
                    if !root.show-compromised-mode && !root.show-add-form && !root.show-folder-mgmt && !root.sp-showing-detail && root.selected-folder-index >= 0 : VerticalLayout {
                        alignment: center;
                        AddToggleButton {
                            active: root.show-add-form;
                            clicked => {
                                root.show-add-form = true;
                                root.on-select-password("");
                                if sp-sidebar.narrow { sp-sidebar.minimized = true; }
                            }
                        }
                    }
                }
            }

            ScrollView {
                vertical-stretch:   1;
                horizontal-stretch: 1;

                VerticalLayout {
                    alignment: start;

                    // Gestão de pastas
                    if root.show-folder-mgmt : FolderManagementPanel {
                        folders:      root.folders;
                        error-rename: root.error-rename;
                        error-remove: root.error-remove;
                        error-create: root.error-create;

                        on-rename(old, new) => { root.on-rename-folder(old, new); }
                        on-remove(name)     => { root.on-remove-folder(name); }
                        on-create(name)     => { root.on-create-folder(name); }
                        on-close            => { root.show-folder-mgmt = false; }
                    }

                    // Formulário de adicionar senha
                    if !root.show-folder-mgmt && root.show-add-form && root.selected-folder-index >= 0 && root.selected-folder-index < root.folders.length : AddStaticPasswordForm {
                        folder-name: root.folders[root.selected-folder-index].name;
                        error:       root.error-add;

                        on-submit(label, value, notes) => {
                            root.sp-pending-label = label;
                            root.sp-pending-value = value;
                            root.sp-pending-notes = notes;
                            root.sp-auth-action   = "add";
                            root.sp-show-auth     = true;
                        }
                        on-cancel => { root.show-add-form = false; }
                    }

                    // Lista de senhas da pasta (sem pw selecionada)
                    if !root.show-folder-mgmt && !root.show-add-form && !root.sp-showing-detail && root.selected-folder-index >= 0 : VerticalLayout {
                        padding: 6px;
                        spacing: 2px;

                        if root.passwords.length == 0 : EmptyState {
                            title:   "Pasta vazia";
                            message: root.show-compromised-mode ? "Nenhuma senha comprometida nesta pasta." : "Clique em + para adicionar uma senha.";
                        }

                        for pw[i] in root.passwords : StaticPasswordListItem {
                            item:     pw;
                            selected: i == root.selected-pw-index;
                            clicked => {
                                root.show-add-form = false;
                                root.on-select-password(pw.uuid);
                            }
                        }
                    }

                    // Detalhe da senha selecionada
                    if root.sp-showing-detail : StaticPasswordDetailPanel {
                        detail:           root.selected-detail;
                        value-visible:    root.value-visible;
                        notes-visible:    root.notes-visible;
                        error-decrypt:    root.error-decrypt;
                        error-compromise: root.error-compromise;

                        on-view             => { root.sp-auth-action = "view";       root.sp-show-auth = true; }
                        on-view-notes       => { root.sp-auth-action = "view-notes";  root.sp-show-auth = true; }
                        on-copy             => { root.sp-auth-action = "copy";       root.sp-show-auth = true; }
                        on-close-value      => { root.on-close-value(); }
                        on-close-notes      => { root.on-close-notes(); }
                        on-mark-compromised => { root.sp-auth-action = "compromise"; root.sp-show-auth = true; }
                        on-remove           => { root.on-remove-request(root.selected-detail.uuid); }
                        on-rename(name) => {
                            root.sp-pending-label = name;
                            root.sp-auth-action   = "rename";
                            root.sp-show-auth     = true;
                        }
                        on-edit-notes(notes) => {
                            root.sp-pending-notes = notes;
                            root.sp-auth-action   = "edit-notes";
                            root.sp-show-auth     = true;
                        }
                    }

                    // Empty state - nenhuma pasta selecionada
                    if !root.show-folder-mgmt && !root.show-add-form && root.selected-folder-index < 0 : EmptyState {
                        title:        "Selecione uma pasta";
                        message:      "Escolha uma pasta no painel à esquerda, ou clique em \"Gerir pastas\" para criar uma nova pasta e depois adicionar uma senha estática.";
                        action-label: "Gerir pastas";
                        on-action => { root.show-folder-mgmt = true; }
                    }
                }
            }
        }
    }

    }

    // Modal de autenticação (overlay de toda a view)
    AuthenticationModal {
        show:       root.sp-show-auth;
        hw-enabled: false;
        overlay-extend-top: Tokens.header-height;
        on-pick-path(_kind, _current) => { "" }
        closed => { root.sp-show-auth = false; }
        on-confirm(k1, k2, _k_ext, _xor_a, _xor_b) => {
            root.sp-show-auth = false;
            if root.sp-auth-action == "add" {
                root.on-add(root.sp-pending-label, root.sp-pending-value, root.sp-pending-notes, k1, k2);
            } else if root.sp-auth-action == "view" {
                root.on-view(root.selected-detail.uuid, k1, k2);
            } else if root.sp-auth-action == "view-notes" {
                root.on-view-notes(root.selected-detail.uuid, k1, k2);
            } else if root.sp-auth-action == "copy" {
                root.on-copy(root.selected-detail.uuid, k1, k2);
            } else if root.sp-auth-action == "compromise" {
                root.on-mark-compromised(root.selected-detail.uuid, k1, k2);
            } else if root.sp-auth-action == "rename" {
                root.on-rename(root.selected-detail.uuid, root.sp-pending-label, k1, k2);
            } else if root.sp-auth-action == "edit-notes" {
                root.on-edit-notes(root.selected-detail.uuid, root.sp-pending-notes, k1, k2);
            }
        }
    }
}