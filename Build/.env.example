# Copie este ficheiro para Build/.env e preenche os valores.
# O ficheiro .env está em .gitignore

VS_PORT=22

# Servidor activo
# Muda VS_SERVER=1 ou VS_SERVER=2 para trocar entre servidores.
# Permite mais servidores adicionando VS_HOST_3, VS_USER_3, etc.
VS_SERVER=1
 
# Server 1 (exemplo: corre localmente nesta máquina)

# IP ou hostname - vazio em modo local (VS_LOCAL_1=true)
VS_HOST_1=
# utilizador SSH
VS_USER_1=Utilizador1
# password (ou deixa vazio se usas chave SSH)
VS_PASS_1=Password1
# os do servidor: linux | nixos| windows
VS_OS_1=windows
# modo local - cada servidor tem o seu próprio VS_LOCAL_<n>
VS_LOCAL_1=true

# Server 2

# IP ou hostname
VS_HOST_2=192.168.1.XX
# utilizador SSH
VS_USER_2=Utilizador2
# password (ou deixa vazio se usas chave SSH)
VS_PASS_2=Password2
# os do servidor: linux | nixos| windows
VS_OS_2=linux

# Server 3 (exemplo: host Windows nativo)

# IP ou hostname
VS_HOST_3=192.168.1.XX
# utilizador (Windows local ou SSH)
VS_USER_3=Utilizador3
# password
VS_PASS_3=Password3
# os do servidor: linux | nixos | windows
VS_OS_3=nixos

# Perfil de targets de compilação (release) - full | release | simple
# VS_PROFILE=full     -> todos os 13 targets
#                        linux: x86_64, i686, aarch64, armv7
#                        windows: x86_64, i686, aarch64  (via cargo xwin)
#                        android: arm64-v8a, armeabi-v7a, x86_64, x86
#                        wasm: wasm32-unknown-unknown, wasm32-wasip1
# VS_PROFILE=release  -> targets essenciais (4)
#                        linux: x86_64
#                        windows: x86_64  (via cargo xwin)
#                        android: arm64-v8a
#                        wasm: wasm32-extension
# VS_PROFILE=simple   -> apenas 1 target
#                        windows: x86_64
VS_PROFILE=full

# Relatório de tempos do cargo (--timings -> cargo-timing-*.html em CARGO_TARGET_DIR/cargo-timings/). 
VS_TIMINGS=false

# RUST_BACKTRACE passado ao cargo no servidor (0 | 1 | full).
VS_BACKTRACE=0

# Fast optimize (lto) - controla LTO
# Build RÁPIDA (LTO desligado). VS_LTO=false: build OTIMIZADA/lenta (LTO=thin)
VS_LTO=true

# Codegen units controla CARGO_PROFILE_RELEASE_CODEGEN_UNITS, ou seja o paralelismo do compilador.
# Mais unidades = mais paralelismo = build mais rápida mas menos otimização
VS_CODEGEN_UNITS=256

# Limite máximo de crates compilados em paralelo (CARGO_BUILD_JOBS), vazio = cargo decide
VS_BUILD_JOBS=

# Override do opt-level usado só para o crate vaultseed-slint
VS_SLINT_OPT_LEVEL=0

# Controla se as compilações (check e release) usam --release (optimizado, build lenta) ou modo debug (sem otimização, build muito mais rápida)
VS_BUILD_RELEASE=true